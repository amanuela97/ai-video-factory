{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "../../",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "paths": {
      "@prompts/*": ["../../packages/prompts/*"]
    }
  },
  "include": ["./**/*.ts", "../../packages/prompts/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
